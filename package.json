{
  "name": "aishwin-design",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "pages:build": "next-on-pages",
    "preview": "next-on-pages && wrangler pages dev .vercel/output/static --compatibility-date=2025-04-01 --compatibility-flag=nodejs_compat",
    "deploy": "next-on-pages && wrangler pages deploy .vercel/output/static --project-name=aish-design",
    "db:local": "wrangler d1 execute aish-design --local --file=./schema.sql",
    "db:remote": "wrangler d1 execute aish-design --remote --file=./schema.sql"
  },
  "dependencies": {
    "next": "15.0.3",
    "react": "19.0.0-rc-66855b96-20241106",
    "react-dom": "19.0.0-rc-66855b96-20241106",
    "clsx": "2.1.1"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.7",
    "@cloudflare/workers-types": "^4.20250410.0",
    "@types/node": "^22.7.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.0",
    "vercel": "^39.0.0",
    "wrangler": "^3.99.0"
  }
}
